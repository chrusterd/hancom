# 미국주식 실시간 시세 (Finnhub 무료 API 키)
VITE_FINNHUB_API_KEY=

# 원자재 일간 기준 시세 (FRED 무료 API 키)
VITE_FRED_API_KEY=

# 국내주식·환율·원자재 실시간 시세 프록시 (네이버 금융 비공식 API, 인증 불필요)
# - 로컬 개발: .env.development.local에 http://127.0.0.1:8787 을 넣고 npm run stock-proxy 실행
# - 배포(Netlify): 비워두면 같은 도메인의 Netlify Functions가 처리 (netlify/functions/market.mjs)
# 프록시 호출 실패 시 환율은 Frankfurter(일간), 원자재는 FRED(일간, 키 필요)로 대체됩니다.
VITE_KR_STOCK_PROXY_URL=
